+    # Handle custom:<name> provider format (e.g., custom:chutes)
+    if normalized.startswith("custom:"):
+        from hermes_cli.config import load_config
+        config = load_config()
+        custom_providers = config.get("custom_providers", [])
+
+        # Extract the name part (e.g., "chutes" from "custom:chutes")
+        provider_name = normalized.split(":", 1)[1]
+
+        for entry in custom_providers:
+            if not isinstance(entry, dict):
+                continue
+            display_name = (entry.get("name") or "").strip().lower()
+            if display_name == provider_name or f"custom:{display_name}" == normalized:
+                base_url = entry.get("base_url", "").strip()
+                api_key = entry.get("api_key", "").strip()
+                if base_url:
+                    live = fetch_api_models(api_key, base_url, timeout=8.0)
+                    if live:
+                        return live
